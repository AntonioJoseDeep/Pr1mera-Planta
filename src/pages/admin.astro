---
const P1_TOTAL_MESAS = 20;
---
<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Panel de Reservas · Pr1mera Planta</title>
<meta name="robots" content="noindex, nofollow">

<script is:inline src="https://cdn.tailwindcss.com"></script>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,400;0,9..144,500;0,9..144,600&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">

<script is:inline>
  tailwind.config = {
    theme: {
      extend: {
        colors: {
          ink: '#19120D', surface: '#241A14', surface2: '#2D2018',
          copper: '#C9854B', copperlight: '#E2A86C', sage: '#7E8F62',
          cream: '#F4E9DA', mute: '#B6A493', line: 'rgba(244,233,218,0.12)',
        },
        fontFamily: { display: ['"Fraunces"', 'serif'], sans: ['"Inter"', 'sans-serif'] },
      }
    }
  }
</script>

<style>
  body { background-color: #19120D; }
  .field-input:focus { outline: none; border-color: #C9854B; background-color: rgba(244,233,218,0.06); }
  .bar-fill { transition: width .4s ease; }
</style>
</head>
<body class="bg-ink text-cream font-sans antialiased min-h-screen">

<!-- ============ LOGIN GATE ============ -->
<div id="loginGate" class="min-h-screen flex items-center justify-center px-6">
  <form id="loginForm" class="w-full max-w-sm bg-surface border border-line rounded-2xl p-8">
    <p class="font-display text-2xl">Pr<span class="text-copperlight">1</span>mera Planta</p>
    <p class="text-mute text-sm mt-1 mb-6">Panel de reservas — acceso interno</p>
    <label for="pass" class="block text-xs eyebrow uppercase text-mute mb-2">Contraseña</label>
    <input type="password" id="pass" class="field-input w-full bg-ink/60 border border-line rounded-lg px-4 py-3 text-cream mb-2" placeholder="••••••••">
    <p id="loginError" class="hidden text-red-400 text-xs mb-3">Contraseña incorrecta.</p>
    <button class="w-full bg-copper text-ink font-semibold px-6 py-3 rounded-full mt-2">Entrar</button>
  </form>
</div>

<!-- ============ PANEL ============ -->
<div id="panel" class="hidden">
  <header class="border-b border-line">
    <div class="max-w-6xl mx-auto px-6 py-5 flex items-center justify-between">
      <div>
        <p class="font-display text-xl">Panel de Reservas</p>
        <p class="text-mute text-xs mt-0.5">Pr1mera Planta · Green Park Altorreal</p>
      </div>
      <div class="flex items-center gap-4">
        <a href="/" class="text-mute text-sm hover:text-copperlight transition">Ver web</a>
        <button id="logoutBtn" class="text-sm border border-line rounded-full px-4 py-2 hover:border-copper hover:text-copperlight transition">Salir</button>
      </div>
    </div>
  </header>

  <main class="max-w-6xl mx-auto px-6 py-10">

    <div class="bg-amber-200/10 border border-amber-300/30 text-amber-100 text-sm rounded-xl px-5 py-4 mb-8 leading-relaxed">
      <strong>Conectado al servidor:</strong> estas reservas se guardan en una base de datos compartida. Verás aquí las reservas hechas por los clientes desde cualquier dispositivo.
    </div>

    <div class="flex flex-wrap items-end gap-4 mb-10">
      <div class="relative">
        <label for="fechaPanelDisplay" class="block text-xs eyebrow uppercase text-mute mb-2">Día</label>
        <button type="button" id="fechaPanelDisplay"
          class="field-input bg-surface border border-line rounded-lg px-4 py-3 text-cream flex items-center gap-2">
          <span id="fechaPanelText">—</span>
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-mute" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5A2.25 2.25 0 0121 11.25v7.5" />
          </svg>
        </button>
        <div id="calendarPanelPopup" class="hidden absolute z-20 mt-2 bg-surface border border-copper/40 rounded-2xl p-4 shadow-2xl w-80">
          <div class="flex items-center justify-between mb-3">
            <button type="button" id="calPanelPrev" class="h-8 w-8 rounded-full border border-line flex items-center justify-center hover:border-copper hover:text-copperlight transition">‹</button>
            <span id="calPanelLabel" class="font-display text-sm text-cream"></span>
            <button type="button" id="calPanelNext" class="h-8 w-8 rounded-full border border-line flex items-center justify-center hover:border-copper hover:text-copperlight transition">›</button>
          </div>
          <div class="grid grid-cols-7 gap-1 text-center text-[10px] text-mute mb-1">
            <span>L</span><span>M</span><span>X</span><span>J</span><span>V</span><span>S</span><span>D</span>
          </div>
          <div id="calPanelGrid" class="grid grid-cols-7 gap-1 text-center text-xs"></div>
        </div>
      </div>
      <div class="flex gap-2">
        <button id="hoyBtn" class="text-sm border border-line rounded-full px-4 py-2.5 hover:border-copper hover:text-copperlight transition">Hoy</button>
        <button id="mananaBtn" class="text-sm border border-line rounded-full px-4 py-2.5 hover:border-copper hover:text-copperlight transition">Mañana</button>
      </div>
      <div class="ml-auto text-right">
        <p id="totalDia" class="font-display text-3xl text-copperlight">0</p>
        <p class="text-xs eyebrow uppercase text-mute">mesas reservadas hoy</p>
      </div>
    </div>

    <!-- Aforo por turno -->
    <div id="aforoGrid" class="grid sm:grid-cols-4 gap-3 mb-12"></div>

    <!-- Lista de reservas del día -->
    <h2 class="font-display text-2xl mb-5">Reservas del día</h2>
    <div id="listaReservas" class="space-y-3"></div>
    <p id="vacioMsg" class="hidden text-mute text-sm border border-line rounded-xl p-8 text-center">No hay reservas para este día todavía.</p>

  </main>
</div>

<!-- ============ MODAL: DETALLE DE RESERVA ============ -->
<div id="detalleModal" class="hidden fixed inset-0 z-[100] items-center justify-center bg-ink/90 backdrop-blur-sm px-6 opacity-0 transition-opacity duration-300">
  <div class="bg-surface border border-copper/40 rounded-3xl max-w-sm w-full p-8 shadow-2xl">
    <div class="flex items-start justify-between mb-6">
      <div>
        <p class="text-xs eyebrow uppercase text-mute">Reserva</p>
        <h3 id="detalleNombre" class="font-display text-2xl mt-1">—</h3>
      </div>
      <button id="cerrarDetalle" aria-label="Cerrar" class="text-mute hover:text-cream transition">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>

    <dl class="space-y-4 text-sm">
      <div class="flex justify-between border-b border-line pb-3">
        <dt class="text-mute">Teléfono</dt>
        <dd id="detalleTelefono" class="font-medium">—</dd>
      </div>
      <div class="flex justify-between border-b border-line pb-3">
        <dt class="text-mute">Correo</dt>
        <dd id="detalleEmail" class="font-medium">—</dd>
      </div>
      <div class="flex justify-between border-b border-line pb-3">
        <dt class="text-mute">Personas</dt>
        <dd id="detallePersonas" class="font-medium">—</dd>
      </div>
      <div class="flex justify-between border-b border-line pb-3">
        <dt class="text-mute">Fecha y turno</dt>
        <dd id="detalleFechaHora" class="font-medium">—</dd>
      </div>
      <div class="flex justify-between border-b border-line pb-3">
        <dt class="text-mute">Estado</dt>
        <dd id="detalleEstado" class="font-medium">—</dd>
      </div>
      <div class="flex justify-between">
        <dt class="text-mute">Reservó el</dt>
        <dd id="detalleCreada" class="font-medium">—</dd>
      </div>
    </dl>

    <div class="flex gap-3 mt-7">
      <a id="detalleLlamar" href="#" class="flex-1 text-center text-sm border border-line rounded-full px-4 py-3 hover:border-copper hover:text-copperlight transition">Llamar</a>
      <a id="detalleCalendar" href="#" target="_blank" rel="noopener" class="flex-1 text-center text-sm border border-line rounded-full px-4 py-3 hover:border-copper hover:text-copperlight transition">+ Calendar</a>
    </div>
    <button id="abrirEditar" class="w-full text-center text-sm bg-copper text-ink font-semibold rounded-full px-4 py-3 mt-3 hover:bg-copperlight transition">Editar reserva</button>
  </div>
</div>

<!-- ============ MODAL: EDITAR RESERVA ============ -->
<div id="editarModal" class="hidden fixed inset-0 z-[110] items-center justify-center bg-ink/90 backdrop-blur-sm px-6 opacity-0 transition-opacity duration-300">
  <div class="bg-surface border border-copper/40 rounded-3xl max-w-sm w-full p-8 shadow-2xl">
    <div class="flex items-start justify-between mb-6">
      <div>
        <p class="text-xs eyebrow uppercase text-mute">Editar reserva</p>
        <h3 id="editarNombre" class="font-display text-2xl mt-1">—</h3>
      </div>
      <button id="cerrarEditar" aria-label="Cerrar" class="text-mute hover:text-cream transition">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>

    <label for="editarFecha" class="block text-xs eyebrow uppercase text-mute mb-2">Fecha</label>
    <input type="date" id="editarFecha" class="field-input w-full bg-ink/60 border border-line rounded-lg px-4 py-3 text-cream mb-4">

    <label class="block text-xs eyebrow uppercase text-mute mb-2">Turno</label>
    <div id="editarTurnoGrid" class="grid grid-cols-4 gap-2 mb-4"></div>

    <label for="editarPersonas" class="block text-xs eyebrow uppercase text-mute mb-2">Personas</label>
    <select id="editarPersonas" class="field-input w-full bg-ink/60 border border-line rounded-lg px-4 py-3 text-cream mb-2">
      <option style="background-color:#19120D; color:#C9854B;">1 persona</option>
      <option style="background-color:#19120D; color:#C9854B;">2 personas</option>
      <option style="background-color:#19120D; color:#C9854B;">3 personas</option>
      <option style="background-color:#19120D; color:#C9854B;">4 personas</option>
      <option style="background-color:#19120D; color:#C9854B;">5 personas</option>
      <option style="background-color:#19120D; color:#C9854B;">6 personas</option>
      <option style="background-color:#19120D; color:#C9854B;">7 o más (llámanos)</option>
    </select>
    <p id="editarError" class="hidden text-red-400 text-xs mb-2"></p>

    <button id="guardarEditar" class="w-full bg-copper text-ink font-semibold rounded-full px-4 py-3 mt-3 hover:bg-copperlight transition">Guardar cambios</button>
  </div>
</div>

<script define:vars={{ P1_TOTAL_MESAS }}>
  // ---------- Acceso ----------
  const loginGate = document.getElementById('loginGate');
  const panel = document.getElementById('panel');
  const loginForm = document.getElementById('loginForm');
  const loginError = document.getElementById('loginError');

  function mostrarPanel() {
    loginGate.classList.add('hidden');
    panel.classList.remove('hidden');
    pintarTodo();
  }

  (async () => {
    const res = await fetch('/api/admin/session');
    const data = await res.json();
    if (data.authenticated) mostrarPanel();
  })();

  loginForm.addEventListener('submit', async (e) => {
    e.preventDefault();
    const val = document.getElementById('pass').value;
    const res = await fetch('/api/admin/login', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ pass: val }),
    });
    if (res.ok) {
      loginError.classList.add('hidden');
      mostrarPanel();
    } else {
      loginError.classList.remove('hidden');
    }
  });

  document.getElementById('logoutBtn').addEventListener('click', async () => {
    await fetch('/api/admin/logout', { method: 'POST' });
    location.reload();
  });

  // ---------- Selector de día (calendario propio) ----------
  const todayStr = new Date().toISOString().split('T')[0];
  const fechaPanelDisplay = document.getElementById('fechaPanelDisplay');
  const fechaPanelText = document.getElementById('fechaPanelText');
  const calendarPanelPopup = document.getElementById('calendarPanelPopup');
  const calPanelGrid = document.getElementById('calPanelGrid');
  const calPanelLabel = document.getElementById('calPanelLabel');
  const calPanelPrev = document.getElementById('calPanelPrev');
  const calPanelNext = document.getElementById('calPanelNext');

  const MESES = ['enero','febrero','marzo','abril','mayo','junio','julio','agosto','septiembre','octubre','noviembre','diciembre'];
  const fechaPanel = { value: todayStr };
  const todayDate = new Date();
  let calPanelViewYear = todayDate.getFullYear();
  let calPanelViewMonth = todayDate.getMonth(); // 0-indexed
  let conteoMesActual = {};
  fechaPanelText.textContent = fechaFormateadaCorta(todayStr);

  function tomorrowStr() {
    const d = new Date();
    d.setDate(d.getDate() + 1);
    return d.toISOString().split('T')[0];
  }

  function fechaFormateadaCorta(isoStr) {
    const d = new Date(isoStr + 'T00:00:00');
    return d.toLocaleDateString('es-ES', { weekday: 'short', day: 'numeric', month: 'short', year: 'numeric' });
  }

  function setFechaPanel(isoStr) {
    fechaPanel.value = isoStr;
    fechaPanelText.textContent = fechaFormateadaCorta(isoStr);
    pintarTodo();
  }

  async function cargarConteoMes(anio, mes) {
    const res = await fetch(`/api/reservas/mes?anio=${anio}&mes=${mes}`);
    const data = await res.json();
    conteoMesActual = data.conteo;
  }

  async function renderCalendarioPanel() {
    calPanelLabel.textContent = `${MESES[calPanelViewMonth]} ${calPanelViewYear}`;
    await cargarConteoMes(calPanelViewYear, calPanelViewMonth + 1);
    calPanelGrid.innerHTML = '';

    const firstOfMonth = new Date(calPanelViewYear, calPanelViewMonth, 1);
    const startOffset = (firstOfMonth.getDay() + 6) % 7; // lunes=0
    const daysInMonth = new Date(calPanelViewYear, calPanelViewMonth + 1, 0).getDate();

    for (let i = 0; i < startOffset; i++) {
      calPanelGrid.appendChild(document.createElement('span'));
    }

    for (let day = 1; day <= daysInMonth; day++) {
      const iso = `${calPanelViewYear}-${String(calPanelViewMonth + 1).padStart(2, '0')}-${String(day).padStart(2, '0')}`;
      const n = conteoMesActual[iso] || 0;
      const isSelected = iso === fechaPanel.value;
      const btn = document.createElement('button');
      btn.type = 'button';
      btn.className = 'h-12 rounded-lg flex flex-col items-center justify-center transition ' +
        (isSelected ? 'bg-copper text-ink font-semibold' : 'text-cream hover:bg-copper/20');
      btn.innerHTML = `<span>${day}</span>` +
        (n > 0 ? `<span class="text-[10px] ${isSelected ? 'text-ink/70' : 'text-copperlight'}">${n}</span>` : '');
      btn.addEventListener('click', () => {
        setFechaPanel(iso);
        calendarPanelPopup.classList.add('hidden');
        renderCalendarioPanel();
      });
      calPanelGrid.appendChild(btn);
    }
  }

  calPanelPrev.addEventListener('click', () => {
    calPanelViewMonth--;
    if (calPanelViewMonth < 0) { calPanelViewMonth = 11; calPanelViewYear--; }
    renderCalendarioPanel();
  });
  calPanelNext.addEventListener('click', () => {
    calPanelViewMonth++;
    if (calPanelViewMonth > 11) { calPanelViewMonth = 0; calPanelViewYear++; }
    renderCalendarioPanel();
  });

  fechaPanelDisplay.addEventListener('click', () => {
    calendarPanelPopup.classList.toggle('hidden');
    renderCalendarioPanel();
  });

  document.addEventListener('click', (e) => {
    if (!calendarPanelPopup.contains(e.target) && e.target !== fechaPanelDisplay && !fechaPanelDisplay.contains(e.target)) {
      calendarPanelPopup.classList.add('hidden');
    }
  });

  document.getElementById('hoyBtn').addEventListener('click', () => { setFechaPanel(todayStr); });
  document.getElementById('mananaBtn').addEventListener('click', () => { setFechaPanel(tomorrowStr()); });

  window.addEventListener('pageshow', () => {
    if (sessionStorage.getItem('p1_admin') === '1') pintarTodo();
  });

  // ---------- Helper para construir el link de Google Calendar ----------
  function linkGoogleCalendar(r) {
    const [h, m] = r.hora.split(':').map(Number);
    const start = new Date(r.fecha + 'T00:00:00');
    start.setHours(h, m, 0, 0);
    const end = new Date(start.getTime() + 90 * 60000);
    const fmt = (d) => d.toISOString().replace(/[-:]/g, '').split('.')[0] + 'Z';
    const params = new URLSearchParams({
      action: 'TEMPLATE',
      text: 'Reserva Pr1mera Planta — ' + r.nombre,
      dates: fmt(start) + '/' + fmt(end),
      details: 'Reserva para ' + r.personas + ' en Pr1mera Planta. Teléfono del restaurante: 677400400',
      location: 'C.C. Green Park Altorreal, Av. del Golf, 100, 30506 Molina de Segura, Murcia'
    });
    return 'https://calendar.google.com/calendar/render?' + params.toString();
  }

  // ---------- Pintar aforo por turno ----------
  function pintarAforo(slots) {
    const grid = document.getElementById('aforoGrid');
    grid.innerHTML = '';
    slots.forEach(s => {
      const ocupadas = P1_TOTAL_MESAS - s.libres;
      const pct = Math.round((ocupadas / P1_TOTAL_MESAS) * 100);
      const div = document.createElement('div');
      div.className = 'border border-line rounded-xl p-4';
      div.innerHTML = `
        <div class="flex items-baseline justify-between">
          <span class="font-display text-lg">${s.hora}</span>
          <span class="text-xs ${s.completo ? 'text-red-400' : 'text-mute'}">${ocupadas}/${P1_TOTAL_MESAS}</span>
        </div>
        <div class="h-1.5 bg-ink/60 rounded-full mt-3 overflow-hidden">
          <div class="bar-fill h-full ${s.completo ? 'bg-red-400' : 'bg-copper'}" style="width:${pct}%"></div>
        </div>`;
      grid.appendChild(div);
    });
  }

  // ---------- Pintar lista de reservas ----------
  let reservasActuales = [];

  function pintarLista(reservas) {
    const cont = document.getElementById('listaReservas');
    const vacioMsg = document.getElementById('vacioMsg');
    cont.innerHTML = '';

    document.getElementById('totalDia').textContent = reservas.length;

    if (reservas.length === 0) {
      vacioMsg.classList.remove('hidden');
      return;
    }
    vacioMsg.classList.add('hidden');

    reservas.forEach(r => {
      const row = document.createElement('div');
      row.className = 'border border-line rounded-xl p-5 flex flex-wrap items-center gap-4 justify-between';
      row.innerHTML = `
        <div class="flex items-center gap-4">
          <span class="font-display text-xl text-copperlight w-16">${r.hora}</span>
          <div>
            <p class="font-medium">${r.nombre}</p>
            <p class="text-mute text-xs mt-0.5">${r.personas} · ${r.telefono}</p>
          </div>
        </div>
        <div class="flex items-center gap-2">
          <button data-id="${r.id}" class="verBtn text-xs border border-copper/50 text-copperlight rounded-full px-4 py-2 hover:bg-copper/10 transition">
            Ver
          </button>
          <button data-id="${r.id}" class="cancelarBtn text-xs border border-red-400/30 text-red-300 rounded-full px-4 py-2 hover:bg-red-400/10 transition">
            Cancelar
          </button>
        </div>`;
      cont.appendChild(row);
    });

    document.querySelectorAll('.verBtn').forEach(btn => {
      btn.addEventListener('click', () => {
        const reserva = reservas.find(r => r.id === btn.dataset.id);
        if (reserva) abrirDetalle(reserva);
      });
    });

    document.querySelectorAll('.cancelarBtn').forEach(btn => {
      btn.addEventListener('click', async () => {
        if (confirm('¿Cancelar esta reserva? Se liberará la mesa en ese turno.')) {
          await fetch('/api/reservas/' + btn.dataset.id, { method: 'PATCH' });
          pintarTodo();
        }
      });
    });
  }

  // ---------- Pop-up de detalle de la reserva ----------
  const detalleModal = document.getElementById('detalleModal');
  let reservaActual = null;

  function abrirDetalle(r) {
    reservaActual = r;
    document.getElementById('detalleNombre').textContent = r.nombre;
    document.getElementById('detalleTelefono').textContent = r.telefono || '—';
    document.getElementById('detalleEmail').textContent = r.email || '— (no indicado)';
    document.getElementById('detallePersonas').textContent = r.personas;

    const fechaFormateada = new Date(r.fecha + 'T00:00:00').toLocaleDateString('es-ES', {
      weekday: 'long', day: 'numeric', month: 'long'
    });
    document.getElementById('detalleFechaHora').textContent = `${fechaFormateada}, ${r.hora}h`;

    const estadoEl = document.getElementById('detalleEstado');
    estadoEl.textContent = r.estado === 'cancelada' ? 'Cancelada' : 'Confirmada';
    estadoEl.className = 'font-medium ' + (r.estado === 'cancelada' ? 'text-red-300' : 'text-sage');

    document.getElementById('detalleCreada').textContent = new Date(r.creada).toLocaleString('es-ES');

    document.getElementById('detalleLlamar').href = 'tel:' + r.telefono;
    document.getElementById('detalleCalendar').href = linkGoogleCalendar(r);

    detalleModal.classList.remove('hidden');
    detalleModal.classList.add('flex');
    requestAnimationFrame(() => detalleModal.classList.remove('opacity-0'));
  }

  function cerrarDetalleModal() {
    detalleModal.classList.add('opacity-0');
    setTimeout(() => {
      detalleModal.classList.add('hidden');
      detalleModal.classList.remove('flex');
    }, 300);
  }

  document.getElementById('cerrarDetalle').addEventListener('click', cerrarDetalleModal);
  detalleModal.addEventListener('click', (e) => {
    if (e.target === detalleModal) cerrarDetalleModal();
  });

  // ---------- Modal: editar reserva ----------
  const editarModal = document.getElementById('editarModal');
  const editarFecha = document.getElementById('editarFecha');
  const editarTurnoGrid = document.getElementById('editarTurnoGrid');
  const editarPersonas = document.getElementById('editarPersonas');
  const editarError = document.getElementById('editarError');
  let editarHoraSeleccionada = null;

  async function pintarTurnosEditar(fecha) {
    editarTurnoGrid.innerHTML = '';
    const res = await fetch('/api/reservas?fecha=' + encodeURIComponent(fecha));
    const data = await res.json();

    data.slots.forEach(s => {
      const esLaPropia = fecha === reservaActual.fecha && s.hora === reservaActual.hora;
      const completo = s.completo && !esLaPropia;
      const btn = document.createElement('button');
      btn.type = 'button';
      btn.textContent = s.hora;
      btn.disabled = completo;
      const seleccionado = s.hora === editarHoraSeleccionada;
      btn.className = 'rounded-lg border px-2 py-2 text-xs transition ' +
        (completo ? 'border-line text-mute/30 cursor-not-allowed line-through' :
         seleccionado ? 'bg-copper border-copper text-ink font-semibold' :
         'border-line text-cream hover:border-copper');
      if (!completo) {
        btn.addEventListener('click', () => {
          editarHoraSeleccionada = s.hora;
          pintarTurnosEditar(fecha);
        });
      }
      editarTurnoGrid.appendChild(btn);
    });
  }

  document.getElementById('abrirEditar').addEventListener('click', () => {
    if (!reservaActual) return;
    editarFecha.value = reservaActual.fecha;
    editarPersonas.value = reservaActual.personas;
    editarHoraSeleccionada = reservaActual.hora;
    document.getElementById('editarNombre').textContent = reservaActual.nombre;
    editarError.classList.add('hidden');
    pintarTurnosEditar(reservaActual.fecha);

    cerrarDetalleModal();
    editarModal.classList.remove('hidden');
    editarModal.classList.add('flex');
    requestAnimationFrame(() => editarModal.classList.remove('opacity-0'));
  });

  editarFecha.addEventListener('change', () => {
    editarHoraSeleccionada = null;
    pintarTurnosEditar(editarFecha.value);
  });

  function cerrarEditarModal() {
    editarModal.classList.add('opacity-0');
    setTimeout(() => {
      editarModal.classList.add('hidden');
      editarModal.classList.remove('flex');
    }, 300);
  }
  document.getElementById('cerrarEditar').addEventListener('click', cerrarEditarModal);
  editarModal.addEventListener('click', (e) => {
    if (e.target === editarModal) cerrarEditarModal();
  });

  document.getElementById('guardarEditar').addEventListener('click', async () => {
    if (!editarHoraSeleccionada) {
      editarError.textContent = 'Selecciona un turno.';
      editarError.classList.remove('hidden');
      return;
    }
    const res = await fetch('/api/reservas/' + reservaActual.id, {
      method: 'PATCH',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        action: 'editar',
        fecha: editarFecha.value,
        hora: editarHoraSeleccionada,
        personas: editarPersonas.value,
      }),
    });
    const resultado = await res.json();
    if (!resultado.ok) {
      editarError.textContent = resultado.motivo || 'No se ha podido guardar el cambio.';
      editarError.classList.remove('hidden');
      return;
    }
    cerrarEditarModal();
    pintarTodo();
  });

  async function pintarTodo() {
    const fecha = fechaPanel.value;
    const res = await fetch('/api/reservas?fecha=' + encodeURIComponent(fecha));
    const data = await res.json();
    reservasActuales = data.reservas;
    pintarAforo(data.slots);
    pintarLista(data.reservas);
  }
</script>
</body>
</html>
