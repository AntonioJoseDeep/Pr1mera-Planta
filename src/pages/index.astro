---
const P1_TOTAL_MESAS = 20;
---
<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Pr1mera Planta · Bar Restaurante en Green Park Altorreal, Molina de Segura</title>
<meta name="description" content="Pr1mera Planta — gastronomía, terraza y buen ambiente en el Centro Comercial Green Park Altorreal, Molina de Segura (Murcia). Reserva tu mesa.">

<script is:inline src="https://cdn.tailwindcss.com"></script>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,300;0,9..144,400;0,9..144,500;0,9..144,600;1,9..144,400;1,9..144,500&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">

<script is:inline>
  tailwind.config = {
    theme: {
      extend: {
        colors: {
          ink: '#19120D',
          surface: '#241A14',
          surface2: '#2D2018',
          copper: '#C9854B',
          copperlight: '#E2A86C',
          sage: '#7E8F62',
          cream: '#F4E9DA',
          mute: '#B6A493',
          line: 'rgba(244,233,218,0.12)',
        },
        fontFamily: {
          display: ['"Fraunces"', 'serif'],
          sans: ['"Inter"', 'sans-serif'],
        },
      }
    }
  }
</script>

<style>
  html { scroll-behavior: smooth; }
  body { background-color: #19120D; }
  .badge-floor {
    font-family: 'Fraunces', serif;
    font-variant-numeric: oldstyle-nums;
  }
  .eyebrow {
    letter-spacing: 0.22em;
  }
  .nav-link { position: relative; }
  .nav-link::after {
    content: '';
    position: absolute;
    left: 0; bottom: -4px;
    width: 0%; height: 1px;
    background: #C9854B;
    transition: width .3s ease;
  }
  .nav-link:hover::after { width: 100%; }

  .btn-copper {
    transition: transform .35s cubic-bezier(.2,.8,.2,1), box-shadow .35s ease, background-color .35s ease;
    box-shadow: 0 0 0 0 rgba(201,133,75,0);
  }
  .btn-copper:hover {
    transform: translateY(-2px);
    box-shadow: 0 12px 28px -8px rgba(201,133,75,0.55);
    background-color: #E2A86C;
  }
  .btn-outline {
    transition: all .35s ease;
  }
  .btn-outline:hover {
    background-color: rgba(244,233,218,0.08);
    border-color: #F4E9DA;
    transform: translateY(-2px);
  }

  .hero-bg {
    background-image:
      linear-gradient(180deg, rgba(25,18,13,0.35) 0%, rgba(25,18,13,0.55) 55%, rgba(25,18,13,0.96) 100%),
      url('https://images.unsplash.com/photo-1559339352-11d035aa65de?q=80&w=2400&auto=format&fit=crop');
    background-size: cover;
    background-position: center 35%;
  }

  .level-line {
    position: absolute;
    left: 28px; top: 0; bottom: 0;
    width: 1px;
    background: linear-gradient(180deg, transparent, rgba(201,133,75,0.5), transparent);
  }

  .menu-tab.active {
    color: #19120D;
    background-color: #C9854B;
  }
  .menu-panel { display: none; }
  .menu-panel.active { display: block; }

  .card-dish {
    transition: transform .3s ease, border-color .3s ease, background-color .3s ease;
  }
  .card-dish:hover {
    transform: translateY(-3px);
    border-color: rgba(201,133,75,0.45);
    background-color: rgba(244,233,218,0.04);
  }

  .field-input {
    transition: border-color .25s ease, background-color .25s ease;
  }
  .field-input:focus {
    outline: none;
    border-color: #C9854B;
    background-color: rgba(244,233,218,0.06);
  }
  .field-input:focus-visible, button:focus-visible, a:focus-visible {
    outline: 2px solid #C9854B;
    outline-offset: 2px;
  }

  #successModal {
    transition: opacity .35s ease;
  }

  @media (prefers-reduced-motion: reduce) {
    * { transition: none !important; animation: none !important; }
  }

  .fade-up {
    opacity: 0;
    transform: translateY(18px);
    transition: opacity .7s ease, transform .7s ease;
  }
  .fade-up.in-view {
    opacity: 1;
    transform: translateY(0);
  }
</style>
</head>

<body class="bg-ink text-cream font-sans antialiased">

<!-- ============ NAV ============ -->
<header id="siteHeader" class="fixed top-0 inset-x-0 z-50 transition-colors duration-300">
  <div class="max-w-7xl mx-auto px-6 lg:px-10 flex items-center justify-between h-20">
    <a href="#inicio" class="flex items-center gap-2">
      <span class="badge-floor text-2xl text-copperlight">P<span class="text-cream">1</span></span>
      <span class="font-display text-lg tracking-wide">Pr<span class="text-copperlight">1</span>mera Planta</span>
    </a>

    <nav class="hidden md:flex items-center gap-9 text-sm eyebrow uppercase text-mute">
      <a href="#espacio" class="nav-link hover:text-cream">El Espacio</a>
      <a href="#carta" class="nav-link hover:text-cream">Carta</a>
      <a href="#reservas" class="nav-link hover:text-cream">Reservas</a>
      <a href="#contacto" class="nav-link hover:text-cream">Contacto</a>
    </nav>

    <a href="#reservas" class="hidden md:inline-block btn-copper bg-copper text-ink font-semibold text-sm px-5 py-2.5 rounded-full">
      Reservar Mesa
    </a>

    <button id="menuToggle" aria-label="Abrir menú" class="md:hidden text-cream">
      <svg id="iconOpen" xmlns="http://www.w3.org/2000/svg" class="h-7 w-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5M3.75 17.25h16.5" />
      </svg>
    </button>
  </div>

  <!-- mobile nav -->
  <div id="mobileNav" class="md:hidden hidden bg-ink/98 border-t border-line px-6 py-6 flex flex-col gap-5 text-base">
    <a href="#espacio" class="mobile-link">El Espacio</a>
    <a href="#carta" class="mobile-link">Carta</a>
    <a href="#reservas" class="mobile-link">Reservas</a>
    <a href="#contacto" class="mobile-link">Contacto</a>
    <a href="#reservas" class="btn-copper bg-copper text-ink text-center font-semibold px-5 py-3 rounded-full">Reservar Mesa</a>
  </div>
</header>

<!-- ============ HERO ============ -->
<section id="inicio" class="hero-bg relative min-h-screen flex items-end">
  <div class="max-w-7xl mx-auto w-full px-6 lg:px-10 pb-24 pt-40">
    <div class="inline-flex items-center gap-3 badge-floor border border-copper/50 rounded-full px-4 py-1.5 mb-7 text-xs eyebrow uppercase text-copperlight">
      <span class="h-1.5 w-1.5 rounded-full bg-copper"></span>
      Green Park Altorreal · Molina de Segura
    </div>

    <h1 class="font-display font-medium text-4xl sm:text-5xl lg:text-7xl leading-[1.05] max-w-4xl text-cream">
      Gastronomía, buen ambiente y las mejores vistas en Altorreal
    </h1>

    <p class="mt-6 max-w-xl text-mute text-lg leading-relaxed">
      Una terraza luminosa, una barra con carácter y una carta pensada para compartir. Sube a la primera planta y quédate a disfrutar de la tarde.
    </p>

    <div class="mt-10 flex flex-col sm:flex-row gap-4">
      <a href="#reservas" class="btn-copper bg-copper text-ink font-semibold text-center px-8 py-4 rounded-full">
        Reservar Mesa
      </a>
      <a href="#carta" class="btn-outline border border-cream/40 text-cream font-semibold text-center px-8 py-4 rounded-full">
        Ver la Carta
      </a>
    </div>

    <p class="mt-8 text-mute/80 text-sm max-w-md">
      Aquí el tapeo va a tu ritmo: te traemos la tapa a la mesa y tú decides si la quieres. Solo pagas lo que aceptas.
    </p>
  </div>

  <a href="#espacio" aria-label="Bajar" class="hidden sm:flex absolute bottom-8 right-10 h-11 w-11 rounded-full border border-cream/30 items-center justify-center text-cream/70 hover:text-cream hover:border-cream transition">
    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
      <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" />
    </svg>
  </a>
</section>

<!-- ============ SOBRE NOSOTROS / EL ESPACIO ============ -->
<section id="espacio" class="relative bg-ink py-28 lg:py-36 overflow-hidden">
  <div class="level-line hidden lg:block"></div>
  <div class="max-w-7xl mx-auto px-6 lg:px-10 grid lg:grid-cols-2 gap-16 items-center">
    <div class="fade-up">
      <span class="badge-floor text-copperlight text-sm eyebrow uppercase">01 · El Espacio</span>
      <h2 class="font-display font-medium text-3xl sm:text-4xl lg:text-5xl mt-4 leading-tight">
        Una terraza con altura, en el corazón de Altorreal
      </h2>
      <p class="mt-6 text-mute text-lg leading-relaxed">
        Pr1mera Planta ocupa un rincón privilegiado del Centro Comercial Green Park Altorreal, con una terraza abierta pensada para alargar las sobremesas y un interior cálido donde la barra es protagonista.
      </p>
      <p class="mt-4 text-mute text-lg leading-relaxed">
        Mobiliario en madera y latón, luz cálida al caer la tarde y un servicio cercano: el lugar perfecto para una cerveza rápida en la barra o una comida sin prisa con buena compañía.
      </p>

      <div class="mt-10 grid grid-cols-3 gap-6 border-t border-line pt-8">
        <div>
          <p class="font-display text-3xl text-copperlight">10-20€</p>
          <p class="text-xs eyebrow uppercase text-mute mt-1">Precio medio</p>
        </div>
        <div>
          <p class="font-display text-3xl text-copperlight">Terraza</p>
          <p class="text-xs eyebrow uppercase text-mute mt-1">Al aire libre</p>
        </div>
        <div>
          <p class="font-display text-3xl text-copperlight">20:00</p>
          <p class="text-xs eyebrow uppercase text-mute mt-1">Hora de apertura</p>
        </div>
      </div>
    </div>

    <div class="fade-up grid grid-cols-2 gap-4">
      <img src="https://images.unsplash.com/photo-1517248135467-4c7edcad34c4?q=80&w=1200&auto=format&fit=crop"
           alt="Terraza moderna del restaurante" class="rounded-2xl object-cover h-72 w-full col-span-2 shadow-2xl shadow-black/40">
      <img src="https://images.unsplash.com/photo-1466978913421-dad2ebd01d17?q=80&w=900&auto=format&fit=crop"
           alt="Barra y ambiente del local" class="rounded-2xl object-cover h-44 w-full shadow-xl shadow-black/30">
      <img src="https://images.unsplash.com/photo-1414235077428-338989a2e8c0?q=80&w=900&auto=format&fit=crop"
           alt="Plato preparado en el restaurante" class="rounded-2xl object-cover h-44 w-full shadow-xl shadow-black/30">
    </div>
  </div>
</section>

<!-- ============ CÓMO FUNCIONA EL TAPEO ============ -->
<section class="relative bg-surface2 py-24 lg:py-32 border-y border-line">
  <div class="max-w-7xl mx-auto px-6 lg:px-10">
    <div class="text-center max-w-2xl mx-auto fade-up">
      <span class="badge-floor text-copperlight text-sm eyebrow uppercase">Un tapeo distinto</span>
      <h2 class="font-display font-medium text-3xl sm:text-4xl lg:text-5xl mt-4">Tú decides, tapa a tapa</h2>
      <p class="mt-5 text-mute text-lg">Nada de pedir a ciegas. Vamos pasando por las mesas con cada tapa recién hecha y tú eliges si se queda o no. Así de simple.</p>
    </div>

    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6 mt-14">
      <div class="fade-up border border-line rounded-2xl p-7">
        <span class="badge-floor text-copperlight text-3xl">01</span>
        <h3 class="font-display text-xl mt-4">Te sientas</h3>
        <p class="text-mute text-sm mt-2 leading-relaxed">En la barra o en la terraza, como prefieras.</p>
      </div>
      <div class="fade-up border border-line rounded-2xl p-7">
        <span class="badge-floor text-copperlight text-3xl">02</span>
        <h3 class="font-display text-xl mt-4">Te traemos la tapa</h3>
        <p class="text-mute text-sm mt-2 leading-relaxed">Vamos rotando platos recién salidos de cocina, sin que tengas que pedir nada.</p>
      </div>
      <div class="fade-up border border-line rounded-2xl p-7">
        <span class="badge-floor text-copperlight text-3xl">03</span>
        <h3 class="font-display text-xl mt-4">Tú eliges</h3>
        <p class="text-mute text-sm mt-2 leading-relaxed">Si te apetece, te la dejamos — una por persona en la mesa. Si no, seguimos a la siguiente.</p>
      </div>
      <div class="fade-up border border-line rounded-2xl p-7">
        <span class="badge-floor text-copperlight text-3xl">04</span>
        <h3 class="font-display text-xl mt-4">Pagas lo que has comido</h3>
        <p class="text-mute text-sm mt-2 leading-relaxed">La cuenta se hace solo con las tapas que has aceptado, contadas tal cual.</p>
      </div>
    </div>
  </div>
</section>

<!-- ============ CARTA ============ -->
<section id="carta" class="relative bg-surface py-28 lg:py-36">
  <div class="max-w-7xl mx-auto px-6 lg:px-10">
    <div class="text-center max-w-2xl mx-auto fade-up">
      <span class="badge-floor text-copperlight text-sm eyebrow uppercase">02 · La Carta</span>
      <h2 class="font-display font-medium text-3xl sm:text-4xl lg:text-5xl mt-4">Para compartir, sin prisa</h2>
      <p class="mt-5 text-mute text-lg">Este es el repertorio de tapas que va pasando por las mesas, además de los platos principales y bebidas que puedes pedir directamente. La primera caña y tapa, por solo 3€.</p>
    </div>

    <!-- tabs -->
    <div class="flex justify-center gap-3 mt-12 mb-12 flex-wrap fade-up">
      <button data-tab="tapas" class="menu-tab active px-6 py-2.5 rounded-full text-sm eyebrow uppercase border border-cream/15 transition">Tapas</button>
      <button data-tab="principales" class="menu-tab px-6 py-2.5 rounded-full text-sm eyebrow uppercase border border-cream/15 transition">Platos Principales</button>
      <button data-tab="bebidas" class="menu-tab px-6 py-2.5 rounded-full text-sm eyebrow uppercase border border-cream/15 transition">Bebidas</button>
    </div>

    <!-- TAPAS -->
    <div id="panel-tapas" class="menu-panel active fade-up">
      <div class="max-w-2xl mx-auto border border-copper/40 bg-copper/10 rounded-2xl px-6 py-4 mb-10 text-center">
        <p class="font-display text-xl text-copperlight">1ª caña o bebida + 1ª tapa: 3€</p>
        <p class="text-mute text-sm mt-1">Las siguientes tapas, a 1,50€ / 2€ / 2,50€ según el plato. Solo pagas lo que aceptas en la mesa.</p>
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
        <div class="card-dish border border-line rounded-xl overflow-hidden">
          <img src="https://images.unsplash.com/photo-1601050690597-df0568f70950?q=80&w=900&auto=format&fit=crop" alt="Croquetas de jamón ibérico" class="h-44 w-full object-cover">
          <div class="p-6">
            <div class="flex justify-between items-baseline gap-3"><h3 class="font-display text-xl">Croquetas de jamón ibérico</h3><span class="text-copperlight font-semibold">2,50€</span></div>
            <p class="text-mute text-sm mt-2">Cremosas, hechas a diario.</p>
          </div>
        </div>
        <div class="card-dish border border-line rounded-xl overflow-hidden">
          <img src="https://images.unsplash.com/photo-1639024471283-03518883512d?q=80&w=900&auto=format&fit=crop" alt="Patatas Pr1mera Planta" class="h-44 w-full object-cover">
          <div class="p-6">
            <div class="flex justify-between items-baseline gap-3"><h3 class="font-display text-xl">Patatas Pr1mera Planta</h3><span class="text-copperlight font-semibold">2€</span></div>
            <p class="text-mute text-sm mt-2">Patata confitada, alioli ahumado y crujiente de jamón.</p>
          </div>
        </div>
        <div class="card-dish border border-line rounded-xl overflow-hidden">
          <img src="https://images.unsplash.com/photo-1553621042-f6e147245754?q=80&w=900&auto=format&fit=crop" alt="Tataki de atún rojo" class="h-44 w-full object-cover">
          <div class="p-6">
            <div class="flex justify-between items-baseline gap-3"><h3 class="font-display text-xl">Tataki de atún rojo</h3><span class="text-copperlight font-semibold">2,50€</span></div>
            <p class="text-mute text-sm mt-2">Sésamo tostado, soja dulce y aguacate.</p>
          </div>
        </div>
        <div class="card-dish border border-line rounded-xl overflow-hidden">
          <img src="https://images.unsplash.com/photo-1452195100486-9cc805987862?q=80&w=900&auto=format&fit=crop" alt="Tabla de quesos curados" class="h-44 w-full object-cover">
          <div class="p-6">
            <div class="flex justify-between items-baseline gap-3"><h3 class="font-display text-xl">Tabla de quesos curados</h3><span class="text-copperlight font-semibold">2,50€</span></div>
            <p class="text-mute text-sm mt-2">Selección de queso murciano con mermelada de higo.</p>
          </div>
        </div>
        <div class="card-dish border border-line rounded-xl overflow-hidden">
          <img src="https://images.unsplash.com/photo-1496116218417-1a781b1c416c?q=80&w=900&auto=format&fit=crop" alt="Gyozas de verdura" class="h-44 w-full object-cover">
          <div class="p-6">
            <div class="flex justify-between items-baseline gap-3"><h3 class="font-display text-xl">Gyozas de verdura</h3><span class="text-copperlight font-semibold">2€</span></div>
            <p class="text-mute text-sm mt-2">Salteadas, salsa teriyaki casera.</p>
          </div>
        </div>
        <div class="card-dish border border-line rounded-xl overflow-hidden">
          <img src="https://images.unsplash.com/photo-1590301157890-4810ed352733?q=80&w=900&auto=format&fit=crop" alt="Pan de cristal con tomate" class="h-44 w-full object-cover">
          <div class="p-6">
            <div class="flex justify-between items-baseline gap-3"><h3 class="font-display text-xl">Pan de cristal con tomate</h3><span class="text-copperlight font-semibold">1,50€</span></div>
            <p class="text-mute text-sm mt-2">Aceite de oliva virgen extra y sal en escamas.</p>
          </div>
        </div>
        <div class="card-dish border border-line rounded-xl overflow-hidden">
          <img src="https://images.unsplash.com/photo-1432139509613-5c4255815697?q=80&w=900&auto=format&fit=crop" alt="Carrillera ibérica al vino" class="h-44 w-full object-cover">
          <div class="p-6">
            <div class="flex justify-between items-baseline gap-3"><h3 class="font-display text-xl">Carrillera ibérica al vino</h3><span class="text-copperlight font-semibold">2,50€</span></div>
            <p class="text-mute text-sm mt-2">Cocción lenta, reducción de vino tinto y puré de patata.</p>
          </div>
        </div>
        <div class="card-dish border border-line rounded-xl overflow-hidden">
          <img src="https://images.unsplash.com/photo-1565299585323-38d6b0865b47?q=80&w=900&auto=format&fit=crop" alt="Calamares a la andaluza" class="h-44 w-full object-cover">
          <div class="p-6">
            <div class="flex justify-between items-baseline gap-3"><h3 class="font-display text-xl">Calamares a la andaluza</h3><span class="text-copperlight font-semibold">2,50€</span></div>
            <p class="text-mute text-sm mt-2">Fritos en aceite de oliva, con limón.</p>
          </div>
        </div>
        <div class="card-dish border border-line rounded-xl overflow-hidden">
          <img src="https://images.unsplash.com/photo-1623653387945-2fd25214f8fc?q=80&w=900&auto=format&fit=crop" alt="Gambas al ajillo" class="h-44 w-full object-cover">
          <div class="p-6">
            <div class="flex justify-between items-baseline gap-3"><h3 class="font-display text-xl">Gambas al ajillo</h3><span class="text-copperlight font-semibold">2,50€</span></div>
            <p class="text-mute text-sm mt-2">Ajo dorado, guindilla y un toque de brandy.</p>
          </div>
        </div>
        <div class="card-dish border border-line rounded-xl overflow-hidden">
          <img src="https://images.unsplash.com/photo-1432139555190-58524dae6a55?q=80&w=900&auto=format&fit=crop" alt="Pulpo a la brasa" class="h-44 w-full object-cover">
          <div class="p-6">
            <div class="flex justify-between items-baseline gap-3"><h3 class="font-display text-xl">Pulpo a la brasa</h3><span class="text-copperlight font-semibold">2,50€</span></div>
            <p class="text-mute text-sm mt-2">Pimentón de la Vera y aceite de oliva virgen.</p>
          </div>
        </div>
        <div class="card-dish border border-line rounded-xl overflow-hidden">
          <img src="https://images.unsplash.com/photo-1551782450-a2132b4ba21d?q=80&w=900&auto=format&fit=crop" alt="Doble tapa de la casa" class="h-44 w-full object-cover">
          <div class="p-6">
            <div class="flex justify-between items-baseline gap-3"><h3 class="font-display text-xl">Doble tapa de la casa</h3><span class="text-copperlight font-semibold">2€</span></div>
            <p class="text-mute text-sm mt-2">Dos elaboraciones para compartir, con salsas originales de la casa.</p>
          </div>
        </div>
        <div class="card-dish border border-line rounded-xl overflow-hidden">
          <img src="https://images.unsplash.com/photo-1540420773420-3366772f4999?q=80&w=900&auto=format&fit=crop" alt="Verduras a la brasa" class="h-44 w-full object-cover">
          <div class="p-6">
            <div class="flex justify-between items-baseline gap-3"><h3 class="font-display text-xl">Verduras de temporada a la brasa</h3><span class="text-copperlight font-semibold">1,50€</span></div>
            <p class="text-mute text-sm mt-2">Aceite de oliva virgen extra y sal en escamas.</p>
          </div>
