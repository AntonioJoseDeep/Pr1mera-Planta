  const onScroll = () => {
    if (window.scrollY > 30) {
      header.classList.add('bg-ink/95', 'backdrop-blur-md', 'border-b', 'border-line');
    } else {
      header.classList.remove('bg-ink/95', 'backdrop-blur-md', 'border-b', 'border-line');
    }
  };
  document.addEventListener('scroll', onScroll);
  onScroll();

  // ---------- Menú móvil ----------
  const menuToggle = document.getElementById('menuToggle');
  const mobileNav = document.getElementById('mobileNav');
  menuToggle.addEventListener('click', () => {
    mobileNav.classList.toggle('hidden');
  });
  document.querySelectorAll('.mobile-link').forEach(link => {
    link.addEventListener('click', () => mobileNav.classList.add('hidden'));
  });

  // ---------- Tabs de la carta ----------
  const tabs = document.querySelectorAll('.menu-tab');
  const panels = document.querySelectorAll('.menu-panel');
  tabs.forEach(tab => {
    tab.addEventListener('click', () => {
      tabs.forEach(t => t.classList.remove('active'));
      panels.forEach(p => p.classList.remove('active'));
      tab.classList.add('active');
      document.getElementById('panel-' + tab.dataset.tab).classList.add('active');
    });
  });

  // ---------- Reveal al hacer scroll ----------
  const revealEls = document.querySelectorAll('.fade-up');
  const io = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.classList.add('in-view');
        io.unobserve(entry.target);
      }
    });
  }, { threshold: 0.15 });
  revealEls.forEach(el => io.observe(el));

  // ---------- Fecha mínima = hoy, y la dejamos preseleccionada ----------
  const fechaInput = document.getElementById('fecha');
  const fechaDisplay = document.getElementById('fechaDisplay');
  const fechaDisplayText = document.getElementById('fechaDisplayText');
  const calendarPopup = document.getElementById('calendarPopup');
  const calGrid = document.getElementById('calGrid');
  const calLabel = document.getElementById('calLabel');
  const calPrev = document.getElementById('calPrev');
  const calNext = document.getElementById('calNext');
  const horaInput = document.getElementById('hora'); // hidden input con el valor real
  const turnoGrid = document.getElementById('turnoGrid');
  const turnoWrap = document.getElementById('turnoWrap');
  const aforoNota = document.getElementById('aforoNota');
  const today = new Date().toISOString().split('T')[0];

  const MESES = ['enero','febrero','marzo','abril','mayo','junio','julio','agosto','septiembre','octubre','noviembre','diciembre'];
  const todayDate = new Date();
  let calViewYear = todayDate.getFullYear();
  let calViewMonth = todayDate.getMonth(); // 0-indexed

  function fechaFormateadaCorta(isoStr) {
    const d = new Date(isoStr + 'T00:00:00');
    return d.toLocaleDateString('es-ES', { weekday: 'short', day: 'numeric', month: 'short', year: 'numeric' });
  }

  function setFecha(isoStr) {
    fechaInput.value = isoStr;
    fechaDisplayText.textContent = fechaFormateadaCorta(isoStr);
    pintarTurnos();
  }

  function renderCalendario() {
    calLabel.textContent = `${MESES[calViewMonth]} ${calViewYear}`;
    calGrid.innerHTML = '';

    const firstOfMonth = new Date(calViewYear, calViewMonth, 1);
    const startOffset = (firstOfMonth.getDay() + 6) % 7; // lunes=0
    const daysInMonth = new Date(calViewYear, calViewMonth + 1, 0).getDate();

    for (let i = 0; i < startOffset; i++) {
      calGrid.appendChild(document.createElement('span'));
    }

    for (let day = 1; day <= daysInMonth; day++) {
      const iso = `${calViewYear}-${String(calViewMonth + 1).padStart(2, '0')}-${String(day).padStart(2, '0')}`;
      const btn = document.createElement('button');
      btn.type = 'button';
      btn.textContent = String(day);
      const isPast = iso < today;
      const isSelected = iso === fechaInput.value;
      btn.disabled = isPast;
      btn.className = 'h-8 w-8 rounded-full flex items-center justify-center transition ' +
        (isPast ? 'text-mute/20 cursor-not-allowed' :
         isSelected ? 'bg-copper text-ink font-semibold' :
         'text-cream hover:bg-copper/20');
      if (!isPast) {
        btn.addEventListener('click', () => {
          setFecha(iso);
          calendarPopup.classList.add('hidden');
          renderCalendario();
        });
      }
      calGrid.appendChild(btn);
    }
  }

  calPrev.addEventListener('click', () => {
    calViewMonth--;
    if (calViewMonth < 0) { calViewMonth = 11; calViewYear--; }
    renderCalendario();
  });
  calNext.addEventListener('click', () => {
    calViewMonth++;
    if (calViewMonth > 11) { calViewMonth = 0; calViewYear++; }
    renderCalendario();
  });

  fechaDisplay.addEventListener('click', () => {
    calendarPopup.classList.toggle('hidden');
    renderCalendario();
  });

  document.addEventListener('click', (e) => {
    if (!calendarPopup.contains(e.target) && e.target !== fechaDisplay && !fechaDisplay.contains(e.target)) {
      calendarPopup.classList.add('hidden');
    }
  });

  setFecha(today);

  const P1_TOTAL_MESAS = 20;

  // ---------- Pintar turnos disponibles como botones (consultando la API) ----------
  async function pintarTurnos() {
    const fecha = fechaInput.value;
    turnoGrid.innerHTML = '';
    horaInput.value = '';

    if (!fecha) {
      aforoNota.textContent = 'Elige primero una fecha para ver los turnos.';
      return;
    }

    const res = await fetch('/api/reservas?fecha=' + encodeURIComponent(fecha));
    const data = await res.json();
    const slots = data.slots;

    slots.forEach(s => {
      const btn = document.createElement('button');
      btn.type = 'button';
      btn.dataset.hora = s.hora;
      btn.disabled = s.completo;
      btn.className = 'turno-btn rounded-lg border px-3 py-3 text-sm text-center transition ' +
        (s.completo
          ? 'border-line text-mute/30 cursor-not-allowed line-through'
          : 'border-line text-cream hover:border-copper');
      btn.innerHTML = `<span class="block font-medium">${s.hora}</span>
        <span class="block text-[11px] mt-0.5 ${s.completo ? '' : 'text-mute'}">${s.completo ? 'Completo' : s.libres + ' libres'}</span>`;

      if (!s.completo) {
        btn.addEventListener('click', () => {
          horaInput.value = s.hora;
          turnoGrid.querySelectorAll('.turno-btn').forEach(b => {
            b.classList.remove('bg-copper', 'border-copper', 'text-ink');
          });
          btn.classList.add('bg-copper', 'border-copper', 'text-ink');
          clearError(horaInput);
        });
      }
      turnoGrid.appendChild(btn);
    });

    aforoNota.textContent = `Aforo total: ${P1_TOTAL_MESAS} mesas por turno · se actualiza al confirmar cada reserva.`;
  }

  // ---------- Validación y envío del formulario ----------
  const form = document.getElementById('reservaForm');
  const modal = document.getElementById('successModal');
  const successDetail = document.getElementById('successDetail');
  const addToCalendar = document.getElementById('addToCalendar');
  const closeModal = document.getElementById('closeModal');

  function showError(input, message) {
    const errorEl = input.parentElement.querySelector('.error-msg');
    input.classList.add('border-red-400/70');
    if (errorEl) {
      errorEl.textContent = message;
      errorEl.classList.remove('hidden');
    }
  }

  function clearError(input) {
    const errorEl = input.parentElement.querySelector('.error-msg');
    input.classList.remove('border-red-400/70');
    if (errorEl) errorEl.classList.add('hidden');
  }

  form.addEventListener('submit', async (e) => {
    e.preventDefault();

    const nombre = document.getElementById('nombre');
    const telefono = document.getElementById('telefono');
    const email = document.getElementById('email');
    const personas = document.getElementById('personas');
    const fecha = fechaInput;
    const hora = horaInput;

    [nombre, telefono, email, personas, fecha, hora].forEach(clearError);

    let valid = true;

    if (nombre.value.trim().length < 3) {
      showError(nombre, 'Introduce tu nombre completo.');
      valid = false;
    }

    const phoneDigits = telefono.value.replace(/\s+/g, '');
    if (!/^[6-9]\d{8}$/.test(phoneDigits)) {
      showError(telefono, 'Introduce un teléfono válido (9 dígitos).');
      valid = false;
    }

    if (!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email.value.trim())) {
      showError(email, 'Introduce un correo electrónico válido.');
      valid = false;
    }

    if (!personas.value) {
      showError(personas, 'Selecciona el número de personas.');
      valid = false;
    }

    if (!fecha.value) {
      showError(fecha, 'Selecciona una fecha.');
      valid = false;
    }

    if (!hora.value) {
      showError(hora, 'Selecciona un turno.');
      valid = false;
    }

    if (!valid) return;

    const res = await fetch('/api/reservas', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        nombre: nombre.value.trim(),
        telefono: phoneDigits,
        email: email.value.trim(),
        fecha: fecha.value,
        hora: hora.value,
        personas: personas.value
      })
    });
    const resultado = await res.json();

    if (!resultado.ok) {
      showError(hora, resultado.motivo);
      pintarTurnos();
      return;
    }

    const fechaFormateada = new Date(fecha.value + 'T00:00:00').toLocaleDateString('es-ES', {
      weekday: 'long', day: 'numeric', month: 'long'
    });

    successDetail.textContent = `Hola ${nombre.value.trim().split(' ')[0]}, hemos reservado mesa para ${personas.value} el ${fechaFormateada} a las ${hora.value}h. Te enviaremos la confirmación a ${email.value.trim()} y te llamaremos al ${telefono.value} si hace falta.`;

    const r = resultado.reserva;
    const [h, m] = r.hora.split(':').map(Number);
    const start = new Date(r.fecha + 'T00:00:00');
    start.setHours(h, m, 0, 0);
    const end = new Date(start.getTime() + 90 * 60000);
    const fmt = (d) => d.toISOString().replace(/[-:]/g, '').split('.')[0] + 'Z';
    const params = new URLSearchParams({
      action: 'TEMPLATE',
      text: 'Reserva Pr1mera Planta — ' + r.nombre,
      dates: fmt(start) + '/' + fmt(end),
      details: 'Reserva para ' + r.personas + ' en Pr1mera Planta. Teléfono del restaurante: 677400400',
      location: 'C.C. Green Park Altorreal, Av. del Golf, 100, 30506 Molina de Segura, Murcia'
    });
    addToCalendar.href = 'https://calendar.google.com/calendar/render?' + params.toString();

    modal.classList.remove('hidden');
    modal.classList.add('flex');
    requestAnimationFrame(() => modal.classList.remove('opacity-0'));

    form.reset();
    setFecha(today);
  });


  closeModal.addEventListener('click', () => {
    modal.classList.add('opacity-0');
    setTimeout(() => {
      modal.classList.add('hidden');
      modal.classList.remove('flex');
    }, 350);
  });

  modal.addEventListener('click', (e) => {
    if (e.target === modal) closeModal.click();
  });
</script>

</body>
</html>
